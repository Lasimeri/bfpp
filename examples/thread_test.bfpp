; BF++ Multicore Threading Integration Test
; Exercises: __spawn, __join, __thread_id, __num_cores,
;            __mutex_init, __mutex_lock, __mutex_unlock,
;            __atomic_add, __atomic_load,
;            __barrier_init, __barrier_wait, __yield
;
; Compile:  bfpp examples/thread_test.bfpp -o thread_test --include stdlib
; Run:      ./thread_test
;
; Expected output:
;   Cores: <N>
;   Spawning 4 threads...
;   Joining...
;   T0:1 T1:1 T2:1 T3:1
;   Counter: 4
;   PASS
;
; Memory layout (byte addresses):
;   tape[100..103]  — marker bytes, one per worker (worker 0..3)
;   tape[200]       — shared counter (1-byte, atomically incremented)
;   tape[16]        — worker 0 start region
;   tape[32]        — worker 1 start region
;   tape[48]        — worker 2 start region
;   tape[64]        — worker 3 start region
;
; All intrinsic parameter addresses kept < 256 so %1 cell width suffices
; for multi-parameter intrinsics (e.g., __atomic_add uses tape[ptr+1]=addr).
;
; Thread IDs (64-bit pthread_t) are saved/restored via the value stack ($~)
; which always stores uint64_t regardless of cell width.
;
; NOTE: __spawn requires %8 at ptr for the thread_id output.
; __spawn reads tape[ptr]=sub_index and tape[ptr+8]=start_ptr.
; After spawning, we push the 8-byte thread_id to the stack, then
; pop it before joining.

; ────────────────────────────────────────────
; Worker subroutine — MUST be defined first (index 0 in sub table)
;
; Starts with ptr at its assigned region (16/32/48/64).
; 1. Waits at barrier 0 (sync with all workers)
; 2. Gets its thread index via __thread_id
; 3. Writes marker byte 1 to tape[99 + thread_index]
;    (thread_index is 1-based for spawned threads, so 99+1=100, 99+2=101, etc.)
; 4. Atomically increments shared counter at tape[200]
; 5. Yields CPU
; ────────────────────────────────────────────
!#worker{
    ; ── Barrier sync: all 4 workers wait here before proceeding ──
    %1                          ; 1-byte cells for barrier_wait parameter
    [-]                         ; tape[ptr] = 0 (barrier_id)
    !#__barrier_wait            ; block until all 4 workers arrive

    ; ── Get our thread index ──
    %1
    [-]
    !#__thread_id               ; tape[ptr] = thread index
    ; With %1 cell width, this truncates to 1 byte — fine for indices 1..4

    ; ── Write marker: tape[99 + thread_index] = 1 ──
    ; Direct tape write: navigate to absolute address, set value.
    ; Thread index is at ptr. Compute target addr = 99 + index.
    ; Use @ (goto absolute address): set cell to addr, then @ jumps ptr there.
    ; But we need to preserve the thread index first for the add.
    ; Save thread index on stack.
    $                           ; push thread_index
    ; Compute target address: 99 + thread_index
    >[-]<                       ; clear ptr+1
    [->+<]                      ; move index to ptr+1, ptr+0=0
    > #99                       ; ptr+1 = 99... wait, #99 overwrites ptr+1

    ; Different approach: add 99 to the index
    ; ptr+0 has the thread index. Add 99 to it directly.
    ; Restore: thread index is on stack, let's pop and use it.
    [-]                         ; clear ptr
    ~                           ; pop thread index back to ptr
    ; Now: ptr = thread_index (1..4)
    ; Add 99: use repeated increment... or set ptr+1=99 and add
    >[-] #99 <                  ; ptr+1 = 99, ptr at ptr+0
    >[- <+> ]<                  ; add ptr+1 into ptr+0: ptr+0 = index + 99

    ; ptr+0 = target address (100..103)
    @                           ; jump ptr to that address

    ; Write marker byte
    #1                          ; tape[target] = 1

    ; ── Atomically increment shared counter at tape[200] ──
    ; __atomic_add: tape[ptr]=value, tape[ptr+1]=addr
    ; Need to be at a clean workspace. Use @ to go somewhere safe.
    #10 @                       ; jump ptr to tape[10] (safe scratch)
    %1
    [-] +                       ; tape[ptr] = 1 (increment amount)
    >[-] #200 <                 ; tape[ptr+1] = 200 (counter address)
    !#__atomic_add              ; atomically add 1 to tape[200]

    ; ── Yield CPU ──
    [-]
    !#__yield

    ^                           ; return
}

; ── Include stdlib for print helpers ──
!include "io.bfpp"

; ════════════════════════════════════════════
; Main program starts here
; ════════════════════════════════════════════

; ── Print core count ──
; Use %1 for string operations (strings are byte-oriented)
%1
"Cores: \0"
<<<<<<<<                        ; back 8 bytes (length of "Cores: \0")
!#.>                            ; print "Cores: "

[-]
!#__num_cores                   ; tape[ptr] = core count (truncated to 1 byte, fine for display)
!#.+                            ; print as decimal
#10 . [-]                       ; newline

; ── Initialize mutex 0 ──
[-]                             ; mutex_id = 0
!#__mutex_init

; ── Initialize barrier 0 with count=4 ──
; __barrier_init: tape[ptr]=barrier_id, tape[ptr+1]=count
[-]                             ; barrier_id = 0
>[-] #4 <                      ; count = 4
!#__barrier_init

; ── Initialize shared counter at tape[200] to 0 ──
; Navigate to tape[200] directly and zero it
#200 @                          ; ptr = 200
%1 [-]                          ; tape[200] = 0

; ── Print status ──
; Navigate back to a clean area for string printing
#0 @                            ; ptr = 0 (start of tape)
%1
"Spawning 4 threads...\n\0"
; String is 23 bytes: S p a w n i n g ' ' 4 ' ' t h r e a d s . . . \n \0
<<<<<<<<<<<<<<<<<<<<<<<         ; back 23 bytes
!#.>                            ; print the string

; ── Spawn 4 worker threads ──
; __spawn: tape[ptr]=sub_index(0), tape[ptr+8]=start_ptr
; Output: tape[ptr]=thread_id (64-bit, requires %8)
;
; Strategy: use tape[80] as spawn workspace.
; Set %8 at ptr for sub_index/thread_id, and %8 at ptr+8 for start_ptr.
; After each spawn, push the 64-bit thread_id to the stack.

; Go to spawn workspace
#80 @                           ; ptr = 80

; ── Spawn worker 0 (start at tape[16]) ──
%8                              ; ptr=80: 8-byte cell (for sub_index input / thread_id output)
[-]                             ; sub_index = 0
>>>>>>>>>>>>>>>>>               ; ptr = 88 (ptr+8, but with %8 cell at 80, need ptr_byte+8)
; Actually: ptr+8 bytes = byte 88. Each > moves 1 byte. 8 > from 80 = 88.
; But we already did 17 >. Let me fix this.

; Reset — navigate properly
#80 @                           ; ptr = 80
%8 [-]                          ; tape[80..87] = 0 (sub_index = 0)
; Move 8 bytes to ptr+8
>>>>>>>>                        ; ptr = 88
%8 #16                          ; tape[88..95] = 16 (start_ptr for worker 0)
<<<<<<<<                        ; ptr = 80
!#__spawn                       ; tape[80] = thread_id_0 (64-bit)
$                               ; push thread_id_0 to stack

; ── Spawn worker 1 (start at tape[32]) ──
%8 [-]                          ; sub_index = 0
>>>>>>>> %8 #32 <<<<<<<<        ; start_ptr = 32
!#__spawn
$                               ; push thread_id_1

; ── Spawn worker 2 (start at tape[48]) ──
%8 [-]                          ; sub_index = 0
>>>>>>>> %8 #48 <<<<<<<<        ; start_ptr = 48
!#__spawn
$                               ; push thread_id_2

; ── Spawn worker 3 (start at tape[64]) ──
%8 [-]                          ; sub_index = 0
>>>>>>>> %8 #64 <<<<<<<<        ; start_ptr = 64
!#__spawn
$                               ; push thread_id_3

; ── Print join message ──
#0 @                            ; ptr = 0
%1
"Joining...\n\0"
<<<<<<<<<<<<                    ; back 12 bytes (J o i n i n g . . . \n \0)
!#.>

; ── Join all 4 threads ──
; Stack has (bottom to top): tid_0, tid_1, tid_2, tid_3
; Must pop in reverse order (LIFO): join tid_3 first, then tid_2, etc.
; Go to join workspace
#80 @
%8

; Join thread 3 (top of stack)
[-] ~                           ; pop tid_3 into tape[80]
!#__join

; Join thread 2
[-] ~
!#__join

; Join thread 1
[-] ~
!#__join

; Join thread 0
[-] ~
!#__join

; All threads joined — their writes are now visible.

; ── Verify markers: print "T0:M T1:M T2:M T3:M" ──
; Workers wrote 1 to tape[100], tape[101], tape[102], tape[103]

#0 @                            ; workspace at tape[0]
%1

; Print "T0:"
#84 . [-]                       ; 'T'
#48 . [-]                       ; '0'
#58 . [-]                       ; ':'

; Read tape[100]
#100 @                          ; ptr = 100
%1
!#.+                            ; print marker value (should be 1)

; Print " T1:"
#0 @
#32 . [-]                       ; space
#84 . [-]                       ; 'T'
#49 . [-]                       ; '1'
#58 . [-]                       ; ':'

#101 @
%1
!#.+

; Print " T2:"
#0 @
#32 . [-]
#84 . [-]
#50 . [-]                       ; '2'
#58 . [-]

#102 @
%1
!#.+

; Print " T3:"
#0 @
#32 . [-]
#84 . [-]
#51 . [-]                       ; '3'
#58 . [-]

#103 @
%1
!#.+

; Newline
#0 @
#10 . [-]

; ── Verify shared counter ──
; Print "Counter: "
#67 . [-]                       ; 'C'
#111 . [-]                      ; 'o'
#117 . [-]                      ; 'u'
#110 . [-]                      ; 'n'
#116 . [-]                      ; 't'
#101 . [-]                      ; 'e'
#114 . [-]                      ; 'r'
#58 . [-]                       ; ':'
#32 . [-]                       ; ' '

; Read shared counter from tape[200]
#200 @
%1
!#.+                            ; print counter (should be 4)

#0 @
#10 . [-]                       ; newline

; ── Final validation: counter == 4 → PASS, else FAIL ──
#200 @
%1                              ; read counter as 1-byte value
; tape[ptr] = counter value
----                            ; subtract 4: result 0 if counter was 4

; BF if-else pattern:
;   ptr+0 = condition (0 = pass, nonzero = fail)
;   ptr+1 = else-flag (starts at 1)
;   if ptr+0 nonzero: run fail body, clear else-flag
;   if ptr+1 nonzero: run pass body
>[-]+<                          ; ptr+1 = 1 (else-flag)

[                               ; if condition != 0 → FAIL
    [-]                         ; clear condition
    >-<                         ; clear else-flag (ptr+1 = 0)
    #0 @                        ; go to workspace
    #70 . [-]                   ; 'F'
    #65 . [-]                   ; 'A'
    #73 . [-]                   ; 'I'
    #76 . [-]                   ; 'L'
    #10 . [-]                   ; newline
    #200 @                      ; back to condition cell (now 0, exits loop)
]

>                               ; ptr = else-flag
[                               ; if else-flag == 1 → PASS
    [-]                         ; clear flag
    #0 @                        ; go to workspace
    #80 . [-]                   ; 'P'
    #65 . [-]                   ; 'A'
    #83 . [-]                   ; 'S'
    #83 . [-]                   ; 'S'
    #10 . [-]                   ; newline
]

; ── Clean exit ──
#0 @
[-]
!#__exit
