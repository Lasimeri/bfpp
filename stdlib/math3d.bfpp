; math3d.bfpp — Q16.16 fixed-point math in pure BF++
; Alternative to C intrinsics (__fp_mul, __fp_sin, __mat4_*, etc.)
; Use when C runtime is unavailable or for maximum portability.
;
; All functions operate on 32-bit cells (%4).
; Q16.16 format: upper 16 bits = integer, lower 16 = fraction.
; 65536 = 1.0, 32768 = 0.5, 131072 = 2.0
;
; Tape layout convention:
;   Arguments at ptr+0, ptr+4, ptr+8, ... (each a %4 cell).
;   Results written back to ptr+0.
;   >>>> moves to the next 4-byte cell. <<<< moves back.
;   Each workspace cell must be set to %4 before first use.
;
; PERFORMANCE NOTE:
;   BF++ has no native 32-bit multiply, divide, or shift. The bitwise
;   operators (s, r, &, |) reference ptr+1 which is a continuation byte
;   in %4 mode, making them unusable for 32-bit arithmetic.
;
;   Multiply uses an O(|b|) addition loop — for b = 65536 (1.0), this is
;   ~65536 iterations per multiply. Acceptable for reference/testing on
;   compiled C output, but NOT for real-time rendering. Use the C intrinsics
;   (__fp_mul, __fp_sin, __mat4_rotate, etc.) for performance.
;
;   Division is impractical in pure BF++ (see note on \fpd). Taylor series
;   sin/cos avoid division by using pre-computed Q16.16 reciprocals.
;
; LIMITATIONS:
;   - \fpm: unsigned/positive inputs only. a*b must fit in uint32.
;   - \fps, \fpc: angles must be positive, <= pi. Caller normalizes.
;   - \fpd: stub — use reciprocal multiply or C intrinsic instead.
;   - Signed Q16.16: not supported by these pure BF++ versions.
;     Negation via subtraction loop is O(|x|) which is infeasible for
;     large unsigned representations of negative Q16.16 values.

!define Q16_ONE 65536
!define Q16_HALF 32768
!define Q16_PI 205887
!define Q16_HALF_PI 102944
!define Q16_TWO_PI 411775
!define Q16_INV_6 10923
!define Q16_INV_120 546
!define Q16_INV_5040 13

; ============================================================================
; \fpm — Fixed-point multiply (unsigned, positive values)
; ============================================================================
; Input:  P+0 = a (Q16.16, %4, positive), P+4 = b (Q16.16, %4, positive)
; Output: P+0 = (a * b) >> 16 (Q16.16)
; Destroys: P+4, P+8, P+12
;
; Algorithm:
;   1. acc (P+8) = 0. Loop b times: acc += a.
;   2. result (P+0) = acc / 65536 via nested 256x256 subtract loop.
;
; Performance: O(b) for multiply + O(a) for division step.
; For a=b=65536 (1.0*1.0): ~131K iterations total. Feasible.
;
; Overflow: a*b must be < 2^32. This covers:
;   - Any multiply where one operand is <= 1.0 (65536)
;   - Both operands < ~256.0 (16,777,216)
;   - All Taylor series intermediate products for sin/cos
\fpm{
    >>>>>>>> %4 [-]                 ; [P+8]  acc = 0
    >>>> %4 [-]                     ; [P+12] temp = 0
    <<<<<<<<<<<<                    ; [P+0]

    ; -- Multiply: acc += a, repeated b times --
    >>>>                            ; [P+4] (b)
    [                               ; while b > 0
        -                           ; b--
        ; Non-destructive copy of a (P+0) to P+12, then add P+12 into acc (P+8).
        ; $ doesn't consume P+0, so P+0 retains a throughout.
        <<<< $                      ; [P+0] push a. Stack: [a]
        >>>>>>>>>>>> [-] ~          ; [P+12] = a (pop). Stack: []
        [- <<<< + >>>>]             ; P+12 to P+8: acc += a (P+12 consumed)
        <<<<<<<<                    ; [P+4]
    ]
    <<<<                            ; [P+0]

    ; acc (P+8) = a * b (unsigned, assuming no overflow)

    ; -- Divide acc by 65536 -> result in P+0 --
    ; Method: flag-driven loop. While acc >= 65536: subtract 65536, result++.
    ; Subtraction of 65536 = 256 iterations of 256 decrements (coalesced -).
    ;
    ; Loop structure:
    ;   P+12 = 1 (continue flag)
    ;   while P+12 > 0:
    ;     P+12 = 0 (default: stop)
    ;     if P+8 > 65535: subtract, result++, P+12 = 1 (continue)
    ;     (if P+8 <= 65535, P+12 stays 0, loop exits)

    [-]                             ; [P+0] result = 0

    >>>>>>>>>>>> #1                 ; [P+12] continue_flag = 1
    [                               ; while continue_flag > 0
        [-]                         ; P+12 = 0 (default: stop)
        <<<<                        ; [P+8] (acc)
        ?> #65535 [                 ; if acc > 65535 (non-destructive)
            ; Subtract 65536 from acc via 256 x Decrement(256)
            ; Use P+4 as loop counter (it's 0 from multiply cleanup).
            <<<<                    ; [P+4]
            #256                    ; P+4 = 256
            [                       ; 256 iterations
                -                   ; P+4--
                >>>> ------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------ <<<<
                ; P+8 -= 256, back to P+4
            ]
            >>>>                    ; [P+8] (acc reduced by 65536)

            ; result++
            <<<<<<<< + >>>>>>>>     ; P+0++, back to [P+8]

            ; Set continue flag
            >>>> #1                 ; [P+12] = 1 (keep going)
            <<<<                    ; [P+8]
        ]
        >>>>                        ; [P+12] (either 0=stop or 1=continue)
    ]
    <<<<<<<<<<<<                    ; [P+0] = result = (a * b) / 65536

    ; -- Cleanup --
    >>>> [-]                        ; P+4 = 0
    >>>> [-]                        ; P+8 = 0
    >>>> [-]                        ; P+12 = 0
    <<<<<<<<<<<<                    ; [P+0]

    ^
}

; ============================================================================
; \fpd — Fixed-point divide (STUB)
; ============================================================================
; Division in pure BF++ is impractical for Q16.16:
;   (a << 16) / b requires first multiplying a by 65536 (O(a*65536) additions)
;   then dividing by b (O(result) subtractions). Total: billions of iterations
;   for typical inputs.
;
; WORKAROUND: Use reciprocal multiplication instead of division.
;   x / 6   -> \fpm with P+4 = 10923  (Q16.16 of 1/6)
;   x / 120 -> \fpm with P+4 = 546    (Q16.16 of 1/120)
;   x / 5040-> \fpm with P+4 = 13     (Q16.16 of 1/5040)
;   x / 2   -> \fpm with P+4 = 32768  (Q16.16 of 0.5)
;
; For arbitrary division, use the C intrinsic __fp_div.

; ============================================================================
; \fpc — Fixed-point cosine (2-term Taylor)
; ============================================================================
; cos(x) ~ 1 - x^2/2
; Accuracy: within ~5% for |x| < 1 radian, ~15% at x = pi/2.
;
; Input:  P+0 = angle (Q16.16, positive, <= pi)
; Output: P+0 = cos(angle) (Q16.16)
; Workspace: P+4..P+12 (%4, managed by \fpm)
;
; Algorithm:
;   1. x^2 = fpm(x, x)
;   2. x^2/2 = fpm(x^2, 32768)   [32768 = Q16.16(0.5)]
;   3. result = 65536 - x^2/2     [65536 = Q16.16(1.0)]
\fpc{
    ; x^2 = fpm(x, x)
    $                               ; push x (non-destructive copy)
    >>>> %4 [-] ~                   ; [P+4] = x (pop from stack)
    <<<< \fpm                       ; [P+0] = x^2

    ; x^2/2 = fpm(x^2, 32768)
    >>>> #32768                     ; [P+4] = Q16.16(0.5)
    <<<< \fpm                       ; [P+0] = x^2/2

    ; result = 1.0 - x^2/2
    $                               ; push x^2/2
    >>>> [-] ~                      ; [P+4] = x^2/2 (pop)
    <<<< #65536                     ; [P+0] = 65536 (1.0)
    >>>> [- <<<< - >>>>]           ; [P+0] -= [P+4] (destructive subtract)
    <<<<                            ; [P+0] = 1.0 - x^2/2

    >>>> [-] <<<<                   ; cleanup P+4

    ^
}

; ============================================================================
; \fps — Fixed-point sine (3-term Taylor)
; ============================================================================
; sin(x) ~ x - x^3/6 + x^5/120
; Accuracy: within ~0.5% for |x| < pi/2, ~2% at x = pi.
;
; Input:  P+0 = angle (Q16.16, positive, <= pi)
; Output: P+0 = sin(angle) (Q16.16)
; Workspace: P+4..P+12 (%4, managed by \fpm internally)
; Stack: uses up to 4 slots
;
; Algorithm:
;   x^2 = fpm(x, x)
;   x^3 = fpm(x^2, x)
;   t1 = fpm(x^3, 10923)        [10923 = Q16.16(1/6)]
;   x^5 = fpm(x^3, x^2)
;   t2 = fpm(x^5, 546)          [546 = Q16.16(1/120)]
;   result = x - t1 + t2
;
; Stack management is tracked with [S: ...] comments (bottom to top).
; \fpm uses P+0, P+4 as args and P+8, P+12 as workspace.
; Between \fpm calls, all intermediates live on the stack.
\fps{
    ; [S: empty] P+0 = x

    ; -- Step 1: x^2 = fpm(x, x) --
    $ $ $                           ; push x three times. [S: x x x]
    >>>> %4 [-] ~ <<<<             ; P+4 = x (pop). [S: x x]
    \fpm                            ; P+0 = x^2

    ; -- Step 2: x^3 = fpm(x^2, x) --
    ; Need P+0 = x^2, P+4 = x.
    ; Stack has: x x. Must get x into P+4 without losing x^2.
    ; Stash x^2 in P+8 (safe — fpm cleaned it).
    >>>>>>>> %4 [-] <<<<<<<<        ; clear P+8 (ensure %4)
    $ >>>>>>>> ~ <<<<<<<<           ; push x^2, pop to P+8. P+0 = x^2. [S: x x x^2]
    ; $ pushes x^2. Stack: x x x^2. >>>>>>>> ~ pops x^2 to P+8. Stack: x x.
    ; P+0 still has x^2. P+8 = x^2.

    ; Pop x -> P+4
    >>>> [-] ~ <<<<                 ; P+4 = x (pop). [S: x]
    ; P+0 = x^2, P+4 = x.
    ; Save x^2 (from P+8) back to stack for later use in x^5.
    >>>>>>>> $ <<<<<<<<             ; push P+8 (x^2). [S: x x^2]
    >>>>>>>> [-] <<<<<<<<           ; clear P+8 (fpm will use it)
    \fpm                            ; P+0 = x^3

    ; -- Step 3: t1 = fpm(x^3, 10923) = x^3/6 --
    ; Save x^3 for x^5 computation.
    $                               ; push x^3. [S: x x^2 x^3]
    >>>> #10923 <<<<                ; P+4 = Q16.16(1/6). P+0 = x^3 (unchanged).
    \fpm                            ; P+0 = t1 = x^3/6
    $                               ; push t1. [S: x x^2 x^3 t1]

    ; -- Step 4: x^5 = fpm(x^3, x^2) --
    ; Stack: x x^2 x^3 t1. Need x^3 in P+0, x^2 in P+4.
    ; Pop t1 -> stash in P+8.
    >>>>>>>> %4 [-] ~ <<<<<<<<      ; P+8 = t1 (pop). [S: x x^2 x^3]
    ; Pop x^3 -> P+0
    [-] ~                           ; P+0 = x^3 (pop). [S: x x^2]
    ; Pop x^2 -> P+4
    >>>> [-] ~ <<<<                 ; P+4 = x^2 (pop). [S: x]
    ; Save t1 (from P+8) back to stack.
    >>>>>>>> $ <<<<<<<<             ; push P+8 (t1). [S: x t1]
    >>>>>>>> [-] <<<<<<<<           ; clear P+8 (fpm workspace)
    \fpm                            ; P+0 = x^5 = x^3 * x^2

    ; -- Step 5: t2 = fpm(x^5, 546) = x^5/120 --
    >>>> #546 <<<<                  ; P+4 = Q16.16(1/120). P+0 = x^5.
    \fpm                            ; P+0 = t2 = x^5/120

    ; -- Step 6: result = x - t1 + t2 --
    ; P+0 = t2. Stack: x t1. Need all three.

    ; Save t2 in P+8.
    >>>>>>>> %4 [-] <<<<<<<<        ; clear P+8
    $ >>>>>>>> ~ <<<<<<<<           ; push t2, pop to P+8. [S: x t1]
    ; P+0 = t2 (unchanged). P+8 = t2.

    ; Pop t1 -> P+4
    >>>> [-] ~ <<<<                 ; P+4 = t1 (pop). [S: x]

    ; Pop x -> P+0
    [-] ~                           ; P+0 = x (pop). [S: empty]

    ; P+0 = x, P+4 = t1, P+8 = t2

    ; result = x - t1: subtract P+4 from P+0
    >>>> [- <<<< - >>>>]           ; P+0 -= P+4. P+4 consumed.
    <<<<                            ; [P+0] = x - t1

    ; result += t2: add P+8 to P+0
    >>>>>>>> [- <<<<<<<< + >>>>>>>>]    ; P+0 += P+8. P+8 consumed.
    <<<<<<<<                        ; [P+0] = x - t1 + t2

    ; Cleanup
    >>>> [-] >>>> [-] >>>> [-]
    <<<<<<<<<<<<                    ; [P+0]

    ^
}

; ============================================================================
; \m4i — Matrix identity (pure BF++)
; ============================================================================
; Input:  P+0 = dest address (raw integer, %4)
; Output: 4x4 identity matrix (Q16.16, column-major) at dest address
; Workspace: P+4 (%4)
;
; Uses *#N (deref-set) to write to the destination address.
; The * operator: saves ptr, sets ptr = current_cell_value, executes the
; wrapped operation at that address, then restores ptr.
; So *#65536 at P+0 writes 65536 to tape[P+0_value].
;
; Column-major identity:
;   m[0]=1 m[5]=1 m[10]=1 m[15]=1 (all others = 0)
;   Byte offsets: m[0]=0, m[5]=20, m[10]=40, m[15]=60
\m4i{
    $ $                             ; push dest twice. [S: dest dest]

    ; Zero all 16 elements via deref loop.
    ; Loop 16 times: *#0 (write 0 at current addr), P+0 += 4.
    >>>> %4 #16                     ; [P+4] = 16 (counter)
    <<<<                            ; [P+0]
    >>>> [                          ; while counter > 0
        -                           ; counter--
        <<<< *#0                    ; tape[P+0] = 0
        ++++                        ; P+0 += 4 (next element)
        >>>>                        ; [P+4]
    ]
    <<<<                            ; [P+0] (now = dest + 64)

    ; Restore dest
    [-] ~                           ; P+0 = dest (pop). [S: dest]

    ; Set diagonal: 1.0 = 65536 at offsets 0, 20, 40, 60
    *#65536                                     ; m[0][0] at dest+0
    ++++++++++++++++++++ *#65536               ; m[1][1] at dest+20
    ++++++++++++++++++++ *#65536               ; m[2][2] at dest+40
    ++++++++++++++++++++ *#65536               ; m[3][3] at dest+60

    ; Restore P+0 = dest
    [-] ~                           ; P+0 = dest (pop second copy). [S: empty]

    >>>> [-] <<<<                   ; cleanup P+4

    ^
}

; ============================================================================
; \m4t — Matrix translate (pure BF++)
; ============================================================================
; Input:  P+0 = dest addr (%4), P+4 = tx, P+8 = ty, P+12 = tz (Q16.16)
; Output: Translation matrix at dest (identity + column 3 = [tx, ty, tz, 1])
; Workspace: P+16 (%4)
;
; Column-major translation matrix:
;   m[0]=1   m[4]=0   m[8]=0   m[12]=tx
;   m[1]=0   m[5]=1   m[9]=0   m[13]=ty
;   m[2]=0   m[6]=0   m[10]=1  m[14]=tz
;   m[3]=0   m[7]=0   m[11]=0  m[15]=1
;
; m[12] at dest+48, m[13] at dest+52, m[14] at dest+56.
;
; Uses *~ (deref-pop) to write stack values to arbitrary tape addresses.
; *~ saves ptr, sets ptr = current_cell_value, pops from stack to that
; address, then restores ptr.
\m4t{
    ; Push tx, ty, tz to stack (will pop in reverse for LIFO)
    >>>> $                          ; push tx. [S: tx]
    >>>> $                          ; push ty. [S: tx ty]
    >>>> $                          ; push tz. [S: tx ty tz]
    <<<<<<<<<<<<                    ; [P+0]

    ; Write identity matrix at dest
    \m4i                            ; P+0 = dest (preserved by \m4i)

    ; Write translation column via deref-pop.
    ; Stack LIFO: pop tz first, then ty, then tx.
    ; tz -> dest+56, ty -> dest+52, tx -> dest+48.

    ; dest + 56 = 56 increments
    ++++++++++++++++++++++++++++++++++++++++++++++++++++++++ ; P+0 = dest+56
    *~                              ; tape[dest+56] = tz (pop). [S: tx ty]
    ----                            ; P+0 = dest+52
    *~                              ; tape[dest+52] = ty (pop). [S: tx]
    ----                            ; P+0 = dest+48
    *~                              ; tape[dest+48] = tx (pop). [S: empty]

    ; Restore P+0 = dest (subtract 48)
    ------------------------------------------------ ; P+0 = dest

    ; Cleanup input cells
    >>>> [-] >>>> [-] >>>> [-]
    <<<<<<<<<<<<                    ; [P+0]

    ^
}

; ============================================================================
; \m4r — Matrix rotate Y-axis (pure BF++)
; ============================================================================
; Input:  P+0 = dest addr (%4), P+4 = angle (Q16.16 radians, positive, <= pi)
; Output: Y-axis rotation matrix at dest (column-major)
; Workspace: P+8..P+20 (%4)
;
; Y-rotation matrix (column-major):
;   m[0]=cos   m[4]=0    m[8]=sin    m[12]=0
;   m[1]=0     m[5]=1    m[9]=0      m[13]=0
;   m[2]=-sin  m[6]=0    m[10]=cos   m[14]=0
;   m[3]=0     m[7]=0    m[11]=0     m[15]=1
;
; Byte offsets for rotation elements:
;   m[0]=cos at dest+0, m[2]=-sin at dest+8,
;   m[8]=sin at dest+32, m[10]=cos at dest+40
;
; Uses Taylor-approximate \fps and \fpc for sin/cos computation.
; WARNING: Only accurate for |angle| < ~1.5 radians due to Taylor truncation.
; For general rotation, use the C intrinsic __mat4_rotate.
\m4r{
    ; Save dest to P+16 (outside trig workspace P+0..P+12)
    >>>>>>>>>>>>>>>> %4 [-]
    <<<<<<<<<<<<<<<<                ; ensure P+16 is %4, clear
    $ >>>>>>>>>>>>>>>> ~
    <<<<<<<<<<<<<<<<                ; P+16 = dest. [S: empty]
    ; P+0 = dest (unchanged by $).

    ; Copy angle to P+0 for trig computation.
    >>>> $ <<<<                     ; push P+4 (angle). [S: angle]
    >>>> $ <<<<                     ; push again. [S: angle angle]
    [-] ~                           ; P+0 = angle (pop). [S: angle]

    ; -- cos(angle) --
    ; \fpc uses P+0..P+12
    \fpc                            ; P+0 = cos(angle)

    ; Save cos to P+20.
    >>>>>>>>>>>>>>>>>>>> %4 [-]
    <<<<<<<<<<<<<<<<<<<< ; ensure P+20 is %4, clear
    $ >>>>>>>>>>>>>>>>>>>> ~
    <<<<<<<<<<<<<<<<<<<<            ; P+20 = cos. [S: angle]
    ; P+0 = cos (unchanged).

    ; -- sin(angle) --
    ; Get angle from stack.
    [-] ~                           ; P+0 = angle (pop). [S: empty]
    ; \fps uses P+0..P+12. P+20 has cos (safe — outside workspace).
    \fps                            ; P+0 = sin(angle)

    ; State: P+0 = sin, P+16 = dest, P+20 = cos. [S: empty]

    ; -- Compute -sin = 0 - sin --
    ; Copy sin to P+4, negate via wrapping subtraction into P+8.
    $                               ; push sin. [S: sin]
    >>>> %4 [-] ~                   ; P+4 = sin (pop). [S: empty]
    <<<<                            ; [P+0] = sin
    >>>>>>>> %4 [-] <<<<<<<<        ; P+8 = 0
    >>>> [- >>>>>>>> - <<<<<<<<]    ; while P+4>0: P+4--, P+8-- (wrapping = -sin)
    ; P+4 = 0. P+8 = -sin (two's complement).
    <<<<                            ; [P+0] = sin

    ; State: P+0=sin, P+4=0, P+8=-sin, P+16=dest, P+20=cos. [S: empty]

    ; -- Write identity at dest --
    ; \m4i uses P+0 and P+4 as workspace. Save sin and -sin first.
    $                               ; push sin (P+0). [S: sin]
    >>>>>>>> $                      ; push -sin (P+8). [S: sin -sin]
    <<<<<<<<                        ; [P+0]
    ; Load dest into P+0 for m4i.
    >>>>>>>>>>>>>>>> $
    <<<<<<<<<<<<<<<<                ; push P+16 (dest). [S: sin -sin dest]
    [-] ~                           ; P+0 = dest (pop). [S: sin -sin]
    \m4i                            ; identity at dest. P+0 = dest. P+4 cleaned.

    ; Restore -sin and sin from stack.
    >>>>>>>> %4 [-] ~ <<<<<<<<      ; P+8 = -sin (pop). [S: sin]
    >>>>>>>>>>>> %4 [-] ~ <<<<<<<<<<<<  ; P+12 = sin (pop). [S: empty]
    ; P+0 = dest. P+8 = -sin. P+12 = sin. P+20 = cos.

    ; -- Write rotation elements via deref-pop --
    ; m[0] = cos at dest+0
    ; m[2] = -sin at dest+8
    ; m[8] = sin at dest+32
    ; m[10] = cos at dest+40
    ;
    ; Push in reverse write order (LIFO — last written pushed first):
    ; Write order: dest+0, dest+8, dest+32, dest+40
    ; Push order: cos(m[10]), sin(m[8]), -sin(m[2]), cos(m[0])

    >>>>>>>>>>>>>>>>>>>> $          ; push P+20 (cos for m[10]). [S: cos]
    <<<<<<<<<<<<<<<<<<<<<<<<        ; [P+0] — wait, that's 24 back from P+20. P+20-24=P-4. Wrong!
    ; From P+20: back to P+12 is <<<<<<<< (8 bytes). Back to P+0 is <<<<<<<<<<<<<<<<<<<< (20).
    <<<<<<<<<<<<<<<<<<<<            ; [P+0]
    >>>>>>>>>>>> $                  ; push P+12 (sin for m[8]). [S: cos sin]
    <<<<                            ; [P+8]
    $                               ; push P+8 (-sin for m[2]). [S: cos sin -sin]
    <<<<<<<<                        ; [P+0]
    >>>>>>>>>>>>>>>>>>>> $          ; push P+20 (cos for m[0]). [S: cos sin -sin cos]
    <<<<<<<<<<<<<<<<<<<<            ; [P+0] = dest

    ; Write via *~ (deref-pop)
    ; m[0] = cos at dest+0
    *~                              ; tape[dest] = cos (pop). [S: cos sin -sin]

    ; m[2] = -sin at dest+8
    ++++++++ *~                     ; P+0 = dest+8. tape[dest+8] = -sin. [S: cos sin]

    ; m[8] = sin at dest+32 (need +24 from current dest+8)
    ++++++++++++++++++++++++ *~     ; P+0 = dest+32. tape[dest+32] = sin. [S: cos]

    ; m[10] = cos at dest+40 (need +8 from dest+32)
    ++++++++ *~                     ; P+0 = dest+40. tape[dest+40] = cos. [S: empty]

    ; Restore P+0 = dest (dest+40 - 40 = dest)
    ---------------------------------------- ; 40 decrements. P+0 = dest.

    ; Cleanup workspace
    >>>> [-]                        ; P+4
    >>>> [-]                        ; P+8
    >>>> [-]                        ; P+12
    >>>> [-]                        ; P+16
    >>>> [-]                        ; P+20
    <<<<<<<<<<<<<<<<<<<<            ; [P+0]

    ^
}
