; ╔══════════════════════════════════════════════╗
; ║  BF++ Test: Integer Arithmetic Intrinsics   ║
; ║  __mul, __div, __mod                        ║
; ╚══════════════════════════════════════════════╝
;
; All intrinsics use ptr+4 byte stride. Use %4 mode.
; Each test prints a result character then newline.

%4

; ── Test 1: __mul (6 * 7 = 42) ──
; 42 = '*' in ASCII
#6 >>>> #7 <<<<
!#__mul
.                     ; prints '*' (42)
[-] >>>> [-] <<<<
#10 . [-]

; ── Test 2: __mul (5 * 0 = 0) ──
; Multiply by zero should yield 0
#5 >>>> #0 <<<<
!#__mul
; Result should be 0. Use ?{} to test.
?{
    #70 .             ; 'F' — fail, nonzero
}:{
    #90 .             ; 'Z' — zero confirmed
}
[-] >>>> [-] <<<<
#10 . [-]

; ── Test 3: __mul (3 * 3 = 9) ──
; 9 + 48 = 57 = '9'
#3 >>>> #3 <<<<
!#__mul
; result = 9, add 48 to make ASCII digit
++++++++++++++++++++++++++++++++++++++++++++++++  ; +48
.                     ; prints '9'
[-] >>>> [-] <<<<
#10 . [-]

; ── Test 4: __div (42 / 6 = 7, remainder 0) ──
; __div: P+0=a, P+4=b → P+0=a/b, P+4=a%b
#42 >>>> #6 <<<<
!#__div
; P+0 = 7, P+4 = 0
; 7 + 48 = 55 = '7'
++++++++++++++++++++++++++++++++++++++++++++++++  ; +48
.                     ; prints '7'
[-]
; Check remainder at P+4 is 0
>>>> ?{
    #70 .             ; 'F' — fail, remainder nonzero
}:{
    #82 .             ; 'R' — remainder zero confirmed
}
[-] <<<<
#10 . [-]

; ── Test 5: __div with remainder (17 / 5 = 3 rem 2) ──
#17 >>>> #5 <<<<
!#__div
; P+0 = 3, P+4 = 2
; quotient: 3 + 48 = 51 = '3'
++++++++++++++++++++++++++++++++++++++++++++++++  ; +48
.                     ; prints '3'
[-]
; remainder: P+4 = 2, + 48 = 50 = '2'
>>>>
++++++++++++++++++++++++++++++++++++++++++++++++  ; +48
.                     ; prints '2'
[-] <<<<
#10 . [-]

; ── Test 6: __mod (17 % 5 = 2) ──
#17 >>>> #5 <<<<
!#__mod
; P+0 = 2
; 2 + 48 = 50 = '2'
++++++++++++++++++++++++++++++++++++++++++++++++  ; +48
.                     ; prints '2'
[-] >>>> [-] <<<<
#10 . [-]

; ── Test 7: __mod (10 % 2 = 0) ──
#10 >>>> #2 <<<<
!#__mod
; P+0 = 0
?{
    #70 .             ; 'F' — fail
}:{
    #69 .             ; 'E' — even (mod 0 confirmed)
}
[-] >>>> [-] <<<<

; ── Summary ──
; Expected output:
; *
; Z
; 9
; 7R
; 32
; 2
; E

%1 #0 !#__exit
