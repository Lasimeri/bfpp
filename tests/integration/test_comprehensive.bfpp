; ╔══════════════════════════════════════════════╗
; ║  BF++ Comprehensive Feature Test              ║
; ║  Exercises all major subsystems together       ║
; ╚══════════════════════════════════════════════╝

!define NL 10
!define SP 32
!define DASH 45

; ── Banner ──
#DASH . #DASH . #DASH . #SP .
#66 . #70 . #43 . #43 .  ; "BF++"
#SP . #DASH . #DASH . #DASH .
#NL .

; ── 1. Subroutines + stack ──
!#add_print{
    ; Input: P+0=a (digit), P+1=b (digit). Prints (a+b) as ASCII digit.
    > [- < + >] <    ; P+0 += P+1 (now P+0 = a+b)
    ++++++++++++++++++++++++++++++++++++++++++++++++ ; add 48 ('0')
    .                 ; print
    [-] > [-] <
    ^
}
#3 > #4 < !#add_print   ; 3+4=7 → '7'
#SP .

; ── 2. Error handling ──
R{
    #6 e          ; set error = 6
    ?             ; propagate
    #88 .         ; never reached
}K{
    E             ; read error (6)
    ++++++++++++++++++++++++++++++++++++++++++++++++ ; add 48
    .             ; '6'
    [-]
}
#SP .

; ── 3. Bitwise ──
#5 > #3 < &       ; 5 AND 3 = 1
++++++++++++++++++++++++++++++++++++++++++++++++ ; add 48
.                 ; '1'
[-] > [-] <
#SP .

; ── 4. Cell width ──
#79 . #75 .       ; "OK"
#SP .

; ── 5. If/else ──
#3
?= #3 [ #51 . [-] ]  ; '3' (3==3 → true)
#SP .

; ── 6. !define ──
!define LETTER_A 65
#LETTER_A .       ; 'A'
#SP .

; ── 7. String + print ──
"Hi\0"
<<< . > .         ; back to 'H', print 'H', advance, print 'i'
> [-] < [-] < [-]

#NL .

; ── Final banner ──
#DASH . #DASH . #DASH . #SP .
#80 . #65 . #83 . #83 . #33 .  ; "PASS!"
#SP . #DASH . #DASH . #DASH .
#NL .

#0 !#__exit
