; ╔══════════════════════════════════════════════╗
; ║  BF++ Test: Advanced Macros & Conditionals  ║
; ║  !define, !undef, ?{...}:{...}              ║
; ╚══════════════════════════════════════════════╝
;
; More thorough than test_macros_ifelse: tests redefine,
; nested conditionals, define-in-arithmetic, conditional chains.

!define NL 10

; ── Test 1: !define + !undef + !define (redefine) ──
!define VAL 65
#VAL .                ; 'A' (65)
!undef VAL
!define VAL 66
#VAL .                ; 'B' (66)
!undef VAL
!define VAL 67
#VAL .                ; 'C' (67)
!undef VAL
#NL . [-]

; ── Test 2: Multiple defines used together ──
!define X 72
!define Y 105
#X .                  ; 'H' (72)
#Y .                  ; 'i' (105)
!undef X
!undef Y
#NL . [-]

; ── Test 3: Nested ?{} — if inside if ──
#5                    ; truthy
?{
    ; outer true branch
    #1                ; also truthy
    ?{
        #89 .         ; 'Y' — inner true
    }:{
        #78 .         ; 'N'
    }
}:{
    #70 .             ; 'F'
}
[-]
#NL . [-]

; ── Test 4: Nested ?{} — if inside else ──
#0                    ; falsy
?{
    #70 .             ; 'F' — should not print
}:{
    ; outer else branch
    #3                ; truthy
    ?{
        #84 .         ; 'T' — inner true in else
    }:{
        #78 .         ; 'N'
    }
}
[-]
#NL . [-]

; ── Test 5: Chained conditionals using ?= #N ──
; ?= #N is non-destructive (compiles to C 'if')
#3                    ; value = 3
?= #1 [
    #49 .             ; '1'
] : [
    ?= #2 [
        #50 .         ; '2'
    ] : [
        ?= #3 [
            #51 .     ; '3' — should match
        ]
    ]
]
[-]
#NL . [-]

; ── Test 6: ?{} with zero result from arithmetic ──
; 5 - 5 = 0 → should take else branch
#5
-----                 ; subtract 5 → 0
?{
    #70 .             ; 'F' — should NOT print
}:{
    #48 .             ; '0' — zero confirmed
}
[-]
#NL . [-]

; ── Test 7: ?{} with define-controlled value ──
!define TRUE 1
!define FALSE 0
#TRUE
?{
    #84 .             ; 'T'
}:{
    #70 .             ; 'F'
}
[-]
#FALSE
?{
    #70 .             ; 'F'
}:{
    #78 .             ; 'N' — false confirmed
}
[-]
!undef TRUE
!undef FALSE

; ── Summary ──
; Expected output:
; ABC
; Hi
; Y
; T
; 3
; 0
; TN

%1 #0 !#__exit
