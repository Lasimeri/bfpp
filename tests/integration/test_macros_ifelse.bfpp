; ╔══════════════════════════════════════════════╗
; ║  BF++ Test Suite: Preprocessor & Control Flow ║
; ║  !define / !undef / ?{...}:{...}              ║
; ╚══════════════════════════════════════════════╝

; ── Test 1: !define basic substitution ──────────
!define STAR 42
!define NEWLINE 10

#STAR .           ; should print '*' (42)
#NEWLINE .        ; newline

; ── Test 2: !define used in arithmetic ──────────
!define TEN 10
!define FOUR 4

#TEN > #FOUR <    ; P+0=10, P+1=4
[->>+<<]          ; not a real subtract, just test defines work
; If we got here without error, defines resolved correctly
#79 . #75 .       ; "OK"
#NEWLINE .

; ── Test 3: !undef removes a macro ──────────────
!define TEMP 65
#TEMP .           ; 'A' (65)
!undef TEMP
; TEMP is now undefined — using it would be literal text
; (which BF++ ignores as non-operator characters)
#66 .             ; 'B' (66) — proof we continued past undef
#NEWLINE .

; ── Test 4: ?{true}:{false} — nonzero ──────────
#1                ; cell = 1 (truthy)
?{
    #89 .         ; 'Y' — should print (cell was nonzero)
}:{
    #78 .         ; 'N' — should NOT print
}
#NEWLINE .

; ── Test 5: ?{true}:{false} — zero ─────────────
#0                ; cell = 0 (falsy)
?{
    #78 .         ; 'N' — should NOT print
}:{
    #89 .         ; 'Y' — should print (cell was zero → else branch)
}
#NEWLINE .

; ── Test 6: ?{} nested with arithmetic ──────────
#5                ; cell = 5
?{
    #80 .         ; 'P' — prints (5 is truthy)
}:{
    #70 .         ; 'F'
}
; After ?{}: body may have written to cell. Clear explicitly.
[-]
; Verify cell is now 0
?{
    #70 .         ; 'F' — should NOT print (cell is 0)
}:{
    #48 .         ; '0' — prints (cell is 0)
}
#NEWLINE .

; ── Summary ──
; Expected output:
; *
; OK
; AB
; Y
; Y
; P0

#0 !#__exit
