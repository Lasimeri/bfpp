; Push values, pop in reverse
#65 $ [-]   ; push 'A', clear cell
#66 $ [-]   ; push 'B'
#67 $ [-]   ; push 'C'

; Pop and print (LIFO: C, B, A)
~ .         ; 'C'
[-] ~ .     ; 'B'
[-] ~ .     ; 'A'

; Test T (tape address) — push address, verify it's nonzero
[-]
T           ; push &tape[ptr]
~           ; pop address into cell
; Address should be nonzero (it's a C pointer)
; if nonzero: print 'Y', else print 'N'
[
    [-]             ; clear the large pointer value
    #89 . [-]       ; print 'Y', clear
]

#10 .               ; newline
